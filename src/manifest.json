{
    "name": "Novel Reader",
    "description": "A simple, unified reader",
    "version": "0.0.1",
    "manifest_version": 3,
    "background": {
        "service_worker": "service_worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "js": ["content_script.js"],
            "matches": [
                "https://novelbin.com/b/*/*"
            ]
        }
    ]
}